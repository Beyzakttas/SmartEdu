<%- include('partials/_header') %>
<%- include('partials/_navigation') %>

<style>
    /* Form kutusu tasarımı */
    .contact_form {
        background-color: #ffffff !important;
        padding: 40px;
        border-radius: 8px;
        box-shadow: 0px 0px 25px rgba(0,0,0,0.05);
        border: 1px solid #f1f1f1;
    }
    
    /* BUTONU SABİTLEME (Küçülme ve Büyümeyi Tamamen Durdurur) */
    #loginform .hover-btn-new.log.orange {
        /* Animasyonları sıfırla */
        transition: none !important; 
        transform: none !important;
        animation: none !important;
        
        /* Boyutları Register ile eşitle ve kilitle */
        padding: 12px 35px !important;
        display: inline-block !important;
        cursor: pointer;
        background: #eea412 !important;
        border: 1px solid #eea412 !important;
        color: #ffffff !important;
        font-weight: 600 !important;
        height: auto !important;
        line-height: normal !important;
    }

    /* Üzerine gelince sadece renk değişsin, hareket etmesin */
    #loginform .hover-btn-new.log.orange:hover {
        background: #333333 !important;
        border-color: #333333 !important;
        transform: none !important;
    }

    /* TIKLANDIĞINDA (Büyüme-Küçülme Buradaki Focus Yüzünden Oluyor) */
    #loginform .hover-btn-new.log.orange:focus, 
    #loginform .hover-btn-new.log.orange:active {
        /* Tüm hareketleri ve efektleri zorla durdur */
        transform: scale(1) !important;
        transition: none !important;
        outline: none !important;
        box-shadow: none !important;
        
        /* Boyutun aynı kalmasını sağla */
        padding: 12px 35px !important;
        background-color: #eea412 !important;
        color: #ffffff !important;
    }

    /* İçerideki span etiketinin oynamasını engelle */
    #loginform .hover-btn-new span {
        background-color: transparent !important;
        display: inline-block !important;
        transition: none !important;
        transform: none !important;
    }

    .section.lb {
        background-color: #fcfcfc !important;
    }
</style>



<div id="login" class="section lb">
    <div class="container">
        <div class="row">
            <div class="col-xl-6 offset-xl-3 col-md-10 offset-md-1 col-sm-12">
                <div class="contact_form text-center">
                    <div class="section-title text-center">
                        <h3 style="margin-bottom: 30px;">Giriş Yap</h3>
                    </div>

                    <% if (flashMessages.error) { %>
                        <div class="alert alert-danger">
                            <%= flashMessages.error %>
                        </div>
                    <% } %>

                    <form id="loginform" name="loginform" method="POST" action="/users/login">
                        <div class="row row-fluid">
                            <div class="col-lg-12 col-md-12 col-sm-12">
                                <input type="email" name="email" id="email" class="form-control" placeholder="E-posta Adresiniz" required style="margin-bottom: 15px;">
                            </div>
                            <div class="col-lg-12 col-md-12 col-sm-12">
                                <input type="password" name="password" id="password" class="form-control" placeholder="Şifreniz" required style="margin-bottom: 20px;">
                            </div>
                            <div class="col-lg-12 col-md-12 col-sm-12">
                                <button type="submit" id="submit" class="hover-btn-new log orange" onfocus="this.blur()" onmousedown="this.style.transform='none'">
                                    <span>GİRİŞ YAP</span>
                                </button>
                            </div>
                        </div>
                    </form>

                    <div class="text-center mt-4" style="padding-top: 20px;">
                        <p>Hesabınız yok mu? <a href="/register" style="color: #eea412; font-weight: bold;">Kayıt Ol</a></p>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/_footer') %>